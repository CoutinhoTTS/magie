{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": [
        "src/renderer/src/*"
      ],
      "~/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "src/renderer/src/env.d.ts",
    "src/types.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.vue",
    "src/preload/*.d.ts",
    "src/types.ts"
  ]
}
