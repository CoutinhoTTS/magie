    "@mastra/libsql": "^1.1.0",
    "@mastra/loggers": "^1.0.1",
    "@mastra/memory": "^1.0.1",
    "@mastra/observability": "^1.1.0",
    "@vueuse/core": "^14.1.0",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "electron-updater": "^6.3.9",
    "element-plus": "^2.13.1",
    "fuse.js": "^7.1.0",
    "katex": "^0.16.27",
    "lucide-vue-next": "^0.562.0",
    "markstream-vue": "0.0.6-beta.9",
    "mastra": "^1.1.0",
    "mermaid": "^11.12.2",
    "moveable": "^0.53.0",
    "openai": "^6.25.0",
    "pinia": "^3.0.4",
